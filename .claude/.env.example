# ─── Required ────────────────────────────────────────────
# AI system name (set during onboarding)
AI_NAME=MyAI

# Full path to the .claude/ directory
AI_DIR=/path/to/your-project/.claude

# Full path to the project root
AI_HOME=/path/to/your-project

# Your timezone (used by cron and briefings)
TIME_ZONE=America/New_York

# ─── Session Summaries (recommended) ────────────────────
# Anthropic API key — used by session-end hook to generate
# session summaries via Haiku. Without this, sessions aren't
# captured automatically.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notifications (optional) ───────────────────────────
# Discord webhook URL for push notifications from cron jobs
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Research Skill (optional) ──────────────────────────
# Perplexity API — deep research with citations
PERPLEXITY_API_KEY=pplx-...

# ─── Other Integrations (add as needed) ─────────────────
# GEMINI_API_KEY=...          # Google AI / NotebookLM
# SERP_API_KEY=...            # Search engine results
# ELEVENLABS_API_KEY=...      # Text-to-speech notifications
# ELEVENLABS_VOICE_ID=...     # Specific TTS voice
